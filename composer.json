{
    "name": "liquiddesign/liquid-monitor-connector",
    "description": "Connector mezi webem a Liquid Monitor",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "LiquidMonitorConnector\\": "src/"
        }
    },
    "bin": [
        "bin/triage-pull"
    ],
    "require": {
        "php": ">=8.1",
        "nette/utils": "^3.0 || ^4.0",
        "nette/http": "^3.0",
        "nette/application": "^3.0",
        "nette/security": "^3.0",
        "tracy/tracy": "^2.0",
        "nette/di": "~3.0",
        "guzzlehttp/guzzle": "^7.0",
        "nesbot/carbon": "^2.0 || ^3.0",
        "liquiddesign/base": "^2.0.33",
        "symfony/console": "^7.0 || ^8.0",
        "symfony/process": "^7.0 || ^8.0",
        "symfony/dotenv": "^7.0 || ^8.0"
    },
    "require-dev": {
        "nette/tester": "^2.0",
        "composer/composer": "~2.0",
        "liquiddesign/codestyle": "~3.0.9",
        "liquiddesign/migrator": "~1.0",
        "phpstan/phpstan-nette": "^2.0",
        "phpcompatibility/php-compatibility": "^9.0"
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "scripts": {
        "fix-code": [
            "@phpcsfix"
        ],
        "code-style": [
            "@phpcsfix",
            "@phpcs"
        ],
        "check-code": [
            "@phpcs",
            "@phpstan"
        ],
        "phpstan": "phpstan analyse --memory-limit 1G -c phpstan.neon",
        "phpcs": "phpcs --standard=ruleset.xml --ignore=assets src",
        "phpcsfix": "phpcbf --standard=ruleset.xml --ignore=assets src",
        "post-install-cmd": [
            "git config core.hooksPath scripts/hooks 2>/dev/null || true"
        ],
        "post-update-cmd": [
            "git config core.hooksPath scripts/hooks 2>/dev/null || true"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.x-dev",
            "dev-1.x": "1.x-dev"
        }
    }
}
