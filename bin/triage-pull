#!/usr/bin/env php
<?php

declare(strict_types=1);

namespace LiquidMonitorConnector\Bin;

use LiquidMonitorConnector\Triage\Agent\AgentRegistry;
use LiquidMonitorConnector\Triage\Agent\ClaudeAgent;
use LiquidMonitorConnector\Triage\Agent\CursorAgent;
use LiquidMonitorConnector\Triage\Commands\TriagePullCommand;
use LiquidMonitorConnector\Triage\MonitorClient;
use LiquidMonitorConnector\Triage\ResultExtractor;
use Symfony\Component\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Console\Output\ConsoleOutput;

// Autoload — works both when run from the package's own checkout
// (vendor/ next to src/) and when installed under a host project
// (… /host/vendor/liquiddesign/liquid-monitor-connector/bin/triage-pull,
//  with the host's autoload at … /host/vendor/autoload.php).
$autoloadCandidates = [
	__DIR__ . '/../vendor/autoload.php',
	__DIR__ . '/../../../autoload.php',
];

$autoloadFound = false;

foreach ($autoloadCandidates as $candidate) {
	if (\is_file($candidate)) {
		require $candidate;
		$autoloadFound = true;

		break;
	}
}

if (!$autoloadFound) {
	\fwrite(\STDERR, "triage-pull: could not locate vendor/autoload.php\n");
	exit(1);
}

// Load .env from CWD if present so cron entries can keep secrets out of the command line.
// Real env vars win over .env values — Dotenv::load() is non-overwriting by default.
$dotenvFile = \getcwd() !== false ? \getcwd() . '/.env' : null;

if ($dotenvFile !== null && \is_file($dotenvFile)) {
	(new \Symfony\Component\Dotenv\Dotenv())->load($dotenvFile);
}

$envOr = static function (string $name, string $default = ''): string {
	$value = \getenv($name);

	if ($value !== false && $value !== '') {
		return $value;
	}

	$fromSuperglobal = $_ENV[$name] ?? $_SERVER[$name] ?? null;

	if (\is_string($fromSuperglobal) && $fromSuperglobal !== '') {
		return $fromSuperglobal;
	}

	return $default;
};

$rawArgs = $_SERVER['argv'] ?? [];
\assert(\is_array($rawArgs));
$scriptName = \array_shift($rawArgs);
$scriptName = \is_string($scriptName) ? $scriptName : 'triage-pull';

// Pre-parse our own non-Symfony options so the Symfony command sees only
// flags it knows about. Anything we don't recognise is forwarded as-is.
$opts = [
	'monitor-url' => $envOr('TRIAGE_MONITOR_URL', $envOr('MONITOR_URL', '')),
	'api-key' => $envOr('TRIAGE_API_KEY', ''),
	'worker-id' => $envOr('TRIAGE_WORKER_ID', \gethostname() !== false ? \gethostname() : 'worker'),
	'max-concurrent' => (int) $envOr('TRIAGE_MAX_CONCURRENT', '1'),
	'agent-timeout' => (int) $envOr('TRIAGE_AGENT_TIMEOUT', '600'),
	'claude-binary' => $envOr('TRIAGE_CLAUDE_BINARY', 'claude'),
	'cursor-binary' => $envOr('TRIAGE_CURSOR_BINARY', 'cursor-agent'),
	'cursor-model' => $envOr('TRIAGE_CURSOR_MODEL', '') ?: null,
];

$forward = [];

foreach ($rawArgs as $arg) {
	if (\str_starts_with($arg, '--')) {
		$eq = \strpos($arg, '=');

		if ($eq !== false) {
			$name = \substr($arg, 2, $eq - 2);
			$value = \substr($arg, $eq + 1);
		} else {
			$name = \substr($arg, 2);
			$value = null;
		}

		if (\array_key_exists($name, $opts)) {
			if ($value === null) {
				\fwrite(\STDERR, "triage-pull: --{$name} requires a value\n");
				exit(1);
			}

			if (\is_int($opts[$name])) {
				$opts[$name] = (int) $value;
			} else {
				$opts[$name] = $value;
			}

			continue;
		}
	}

	$forward[] = $arg;
}

$wantsHelp = \in_array('--help', $forward, true) || \in_array('-h', $forward, true);

if (!$wantsHelp && ($opts['monitor-url'] === '' || $opts['api-key'] === '')) {
	\fwrite(\STDERR, "triage-pull: --monitor-url and --api-key are required (or set TRIAGE_MONITOR_URL/TRIAGE_API_KEY)\n");
	exit(1);
}

$monitor = new MonitorClient($opts['monitor-url'] !== '' ? $opts['monitor-url'] : 'http://invalid.local', $opts['api-key']);
$registry = new AgentRegistry([
	new ClaudeAgent($opts['claude-binary']),
	new CursorAgent($opts['cursor-binary'], $opts['cursor-model']),
]);
$extractor = new ResultExtractor();

$command = new TriagePullCommand(
	monitor: $monitor,
	agents: $registry,
	extractor: $extractor,
	workerId: $opts['worker-id'],
	maxConcurrent: $opts['max-concurrent'],
	agentTimeoutSeconds: $opts['agent-timeout'],
);

$app = new Application('triage-pull', '1.0.0');
$app->addCommand($command);
$app->setDefaultCommand((string) $command->getName(), true);

// Reconstruct argv for Symfony with the script name + only the forwarded args.
\array_unshift($forward, $scriptName);

exit($app->run(new ArgvInput($forward), new ConsoleOutput()));
