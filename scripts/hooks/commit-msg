#!/usr/bin/env bash
# commit-msg hook — validates Conventional Commits format.
# Install: git config core.hooksPath scripts/hooks

export LC_ALL=C.UTF-8

commit_msg=$(head -1 "$1")

# Allow merge commits and reverts
if [[ "$commit_msg" =~ ^Merge\  ]] || [[ "$commit_msg" =~ ^Revert\  ]]; then
	exit 0
fi

# Conventional Commits pattern: type(optional-scope)!?: description
# Types: feat, fix, refactor, chore, docs, style, test, perf, ci, build, ops
pattern='^(feat|fix|refactor|chore|docs|style|test|perf|ci|build|ops)(\([a-zA-Z0-9_-]+\))?!?: .+'

if [[ ! "$commit_msg" =~ $pattern ]]; then
	echo ""
	echo "ERROR: Commit message does not follow Conventional Commits format."
	echo ""
	echo "  Required: type(optional-scope): description"
	echo ""
	echo "  Types:  feat, fix, refactor, chore, docs, style, test, perf, ci, build, ops"
	echo ""
	echo "  Examples:"
	echo "    feat: add public getUrl method"
	echo "    fix(cron): handle JSON decode errors"
	echo "    chore(release): 1.0.65"
	echo ""
	echo "  Your message: $commit_msg"
	echo ""
	exit 1
fi
