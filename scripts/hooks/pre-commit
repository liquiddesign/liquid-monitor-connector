#!/usr/bin/env bash
# pre-commit hook — runs composer check-code before allowing commit.
# On failure, runs Claude Code to auto-fix errors.
# Install: git config core.hooksPath scripts/hooks

set -e

export LC_ALL=C.UTF-8

echo ""
echo "=== Pre-commit: composer update ==="
composer update --no-interaction --quiet

echo "=== Pre-commit: composer check-code ==="
if composer check-code; then
	echo ""
	echo "=== Pre-commit: all checks passed ==="
	exit 0
fi

# check-code failed — try Claude Code auto-fix
echo ""
echo "=== Pre-commit: check-code failed, running Claude Code auto-fix ==="

claude -p "Run 'composer check-code' in $(pwd), fix all reported errors (phpcs, phpstan). Use 'composer phpcsfix' for code style auto-fix first, then fix remaining errors manually. Do NOT commit. At the end, print a summary of all changes you made." --allowedTools "Bash,Read,Edit,Write,Glob,Grep"

echo ""
echo "=== Pre-commit: Claude auto-fix done. Review changes before committing. ==="
echo ""
echo "Changed files after auto-fix:"
git diff --name-only
echo ""
echo "Run 'git diff' to inspect changes, then 'git commit' again to retry."
exit 1
